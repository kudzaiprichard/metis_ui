# =============================================================================
# Metis Desktop App — Environment Variables
# =============================================================================
# Copy this file to `.env.local` (which is git-ignored) and fill in real values:
#
#     cp .env.example .env.local
#
# Next.js auto-loads `.env.local` for `next dev`, `next build`, and `next start`.
# Variables prefixed with `NEXT_PUBLIC_` are inlined into the client bundle at
# build time — never put secrets behind that prefix.
#
# `NODE_ENV` is set automatically by the Next.js scripts (`dev` → development,
# `build`/`start` → production); do not set it yourself.
# =============================================================================


# -----------------------------------------------------------------------------
# Backend API base URL
# -----------------------------------------------------------------------------
# Read by `src/lib/constants.ts` → `getApiBaseUrl()` in every environment.
# In development this is optional — if unset, the app falls back to the dev
# default `http://127.0.0.1:8000/api/v1` (see `API_CONFIG.DEV_BASE_URL`).
# In production builds it is REQUIRED; an unset value yields an empty base URL
# and every request will fail.
#
# Must include the `/api/v1` version suffix and must NOT have a trailing slash.
# Examples:
#   http://127.0.0.1:8000/api/v1            (local backend on default port)
#   https://api.metis.example.com/api/v1    (staging / production)
NEXT_PUBLIC_API_BASE_URL=
